<div id="<%= dom_id customer %>">
  <p>
    <strong>Name:</strong>
    <%= customer.name %>
  </p>

  <p>
    <strong>Email:</strong>
    <%= customer.email %>
  </p>

  <p>
    <strong>Mobile:</strong>
    <%= customer.mobile %>
  </p>

  <p>
    <strong>Location:</strong>
    <%= customer.location %>
  </p>

</div>
