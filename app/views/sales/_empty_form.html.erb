<div class="flex items-center justify-between gap-1 px-5">
  <div class="flex-1">
    <%= f.label :empty_type_id, class: "text-xs text-gray-600 dark:text-gray-400" %>
    <%= f.collection_select :empty_type_id, @empties, :id, :name, {prompt: "Choose a empty"}, {class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500", data:{controller:"sale", action: "change->sale#fetchProductDetails"}} %>
  </div>
  <div class="flex-1">
    <%= f.label :expected, class: "text-xs text-gray-600 dark:text-gray-400" %> <i class="text-sm text-red-600 dark:text-red-400">*</i>
    <%= f.text_field :expected, class: "quantity-field bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500", data: { sale_target: "quantity", action: "change->sale#getTotal" } %>
  </div>
  <div class="flex-1">
    <%= f.label :received, class: "text-xs text-gray-600 dark:text-gray-400" %> <i class="text-sm text-red-600 dark:text-red-400">*</i>
    <%= f.text_field :received, class: "amount-field bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500", data: { sale_target: "amount", action: "change->sale#getTotal" } %>
  </div>
  <div class="flex-1">
    <%= f.label :variance, class: "text-xs text-gray-600 dark:text-gray-400" %> <i class="text-sm text-red-600 dark:text-red-400">*</i>
    <%= f.text_field :variance, class: "itemtotal-field bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500", data: { sale_target: "itemtotal" } %>
  </div>
  <div>
        <span class="px-2 py-1 text-xs text-red-200 bg-red-700 rounded dark:text-red-700 dark:bg-red-200">
        <button type="button" data-action="nested-form#remove">Remove <i class="fas fa-trash"></i></button>
        </span>
    </div>
</div>
<%= f.hidden_field :_destroy %>
