<!DOCTYPE html>
<html>
<head>
  <style>
    body {
      font-family: Arial, sans-serif;
      color: #333;
    }
    .header {
      background-color: #3498db;
      color: white;
      padding: 20px;
      text-align: center;
    }
    .logo {
      width: 100px;
    }
    .content {
      margin-top: 20px;
    }
    .content p {
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="header">
    <img src="<%= Rails.root.join('public', 'images', 'logo.png') %>" class="logo" />
    <h1>Order Summary</h1>
  </div>

  <div class="content">
    <p><strong>Order ID:</strong> <%= @order.id %></p>
    <p><strong>Status:</strong> <%= @order.status.name %></p>
    <p><strong>Total Amount:</strong> <%= number_to_currency(@order.total_price) %></p>
  </div>
</body>
</html>
