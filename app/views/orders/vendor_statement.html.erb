<div class="p-4 bg-white dark:bg-gray-900" data-controller="orders">
  <div class="grid w-full grid-cols-2 gap-4 mb-3">
    <div class="col-span-1">
        <h1 class="text-gray-800 text-md dark:text-gray-100">Vendor Statements</h1>
    </div>
    <div class="col-span-1 text-right">
        Export to PDF
    </div> 
  </div>
    <!-- Table -->
  <div class="flex flex-col mt-6">
    <div class="overflow-x-auto border rounded border-slate-300 dark:border-slate-700">
        <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
            <thead class="bg-gray-50 dark:bg-gray-700">
                <tr>
                <th scope="col" class="p-4 text-[10px] font-medium tracking-wider text-left text-gray-500 uppercase dark:text-white">
                    Product.
                </th>
                <th scope="col" class="p-4 text-[10px] font-medium tracking-wider text-left text-gray-500 uppercase dark:text-white">
                    Openning Stock
                </th>
                <th scope="col" class="p-4 text-[10px] font-medium tracking-wider text-left text-gray-500 uppercase dark:text-white">
                    Purchases
                </th>
                <th scope="col" class="p-4 text-[10px] font-medium tracking-wider text-left text-gray-500 uppercase dark:text-white">
                    Used(Breakages, Missing, Complaint, Sales)
                </th>
                <th scope="col" class="p-4 text-[10px] font-medium tracking-wider text-left text-gray-500 uppercase dark:text-white">
                    Closing Stock
                </th>
                <th scope="col" class="p-4 text-[10px] font-medium tracking-wider text-left text-gray-500 uppercase dark:text-white">
                    Empties Returned
                </th>
                </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800">
            <% @statements.each_with_index do |item, index| %>
                <tr class="border-b bg-gray-50 dark:bg-gray-800 dark:border-gray-700">
                <td class="p-4 text-sm font-normal text-gray-900 whitespace-normal dark:text-white">
                    <span class="font-semibold"><%=item.product.name%></span>
                </td>
                <td class="p-4 text-xs font-normal text-gray-900 whitespace-normal dark:text-white">
                    <%= link_to openning_stock_nile_product_path(item.product_id), data:{turbo: false} do%><span class="font-normal"><%= item.opening_stock %></span><%end%>
                </td>
                <td class="p-4 text-xs font-normal text-gray-900 whitespace-normal dark:text-white">
                    <%= link_to quantity_in_nile_product_path(item.product_id), data:{turbo: false} do%><span class="font-normal"><%=item.purchases%></span><%end%>
                </td>
                <td class="p-4 text-xs font-normal text-gray-900 whitespace-normal dark:text-white">
                    <%= link_to quantity_out_nile_product_path(item.product_id), data:{turbo: false} do%><span class="font-normal"><%=item.sales%></span><%end%>
                </td>
                <td class="p-4 text-xs font-normal text-gray-900 whitespace-normal dark:text-white">
                    <span class="font-normal"><%= item.closing_stock %></span>
                </td>
                <td class="p-4 text-xs font-normal text-gray-900 whitespace-normal dark:text-white">
                    <span class="font-normal"></span>
                </td>
                </tr>
            <%end%>
            </tbody>
        </table>
  </div>
  </div>
</div>
