<div class="min-h-screen bg-gradient-to-b from-white to-slate-100">
  

  <!-- Hero -->
  <main class="container px-4 py-20 mx-auto">
    <section class="max-w-4xl mx-auto text-center">
      <span class="inline-block px-4 py-1 text-xs font-semibold text-black bg-yellow-400 rounded-full">
        Kabaco Mbarara Uganda Ltd
      </span>

      <h1 class="mt-6 text-5xl font-bold tracking-tight md:text-7xl">
        Manage your
        <span class="text-green-700">cement &amp; hardware</span>
        supply chain end-to-end.
      </h1>

      <p class="mt-6 text-lg text-slate-600">
        Place purchase orders to suppliers, capture dispatch details (FDN,
        vehicle, driver, invoice), receive and approve stock, and distribute
        to customers — all in one place.
      </p>

      <div class="flex justify-center gap-3 mt-8">
        <a href="users/signup" class="px-6 py-3 font-medium text-white bg-green-700 rounded-md hover:bg-green-800">Get started</a>

        <a href="users/signin" class="px-6 py-3 font-medium bg-white border rounded-md border-slate-300 hover:bg-slate-50">Sign in</a>
      </div>
    </section>

    <!-- Features -->
    <section class="grid gap-6 mt-20 sm:grid-cols-2 lg:grid-cols-4">
      <div class="p-6 bg-white border shadow-sm rounded-xl">
        <div class="flex items-center justify-center w-10 h-10 text-green-700 bg-green-100 rounded-lg">
          📦
        </div>

        <h3 class="mt-4 font-semibold">
          Order from suppliers
        </h3>

        <p class="mt-1 text-sm text-slate-600">
          Create purchase orders with line items and expected delivery dates.
        </p>
      </div>

      <div class="p-6 bg-white border shadow-sm rounded-xl">
        <div class="flex items-center justify-center w-10 h-10 text-green-700 bg-green-100 rounded-lg">
          🚚
        </div>

        <h3 class="mt-4 font-semibold">
          Track dispatch
        </h3>

        <p class="mt-1 text-sm text-slate-600">
          Capture FDN, vehicle, driver and invoice — by supplier or your own staff.
        </p>
      </div>

      <div class="p-6 bg-white border shadow-sm rounded-xl">
        <div class="flex items-center justify-center w-10 h-10 text-green-700 bg-green-100 rounded-lg">
          ✅
        </div>

        <h3 class="mt-4 font-semibold">
          Receive &amp; approve
        </h3>

        <p class="mt-1 text-sm text-slate-600">
          Record received quantities and damages. Store manager approves into stock.
        </p>
      </div>

      <div class="p-6 bg-white border shadow-sm rounded-xl">
        <div class="flex items-center justify-center w-10 h-10 text-green-700 bg-green-100 rounded-lg">
          🏬
        </div>

        <h3 class="mt-4 font-semibold">
          Distribute to customers
        </h3>

        <p class="mt-1 text-sm text-slate-600">
          Customers order online or staff log call-in orders. Fulfil from stock.
        </p>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer class="py-6 text-sm text-center border-t text-slate-500">
    © <%= Time.current.year %> Kabaco Mbarara Uganda Ltd
  </footer>
</div>