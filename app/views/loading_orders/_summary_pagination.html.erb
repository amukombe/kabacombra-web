<nav aria-label="Page navigation example" class="my-3">
    <ul class="inline-flex -space-x-px text-sm">
        <% if @products.prev_page %>
        <li>
            <%= link_to "Previous", url_for(page: @products.prev_page), data:{turbo:false}, class: "flex items-center justify-center px-3 h-8 ms-0 leading-tight text-gray-500 bg-white border border-e-0 border-gray-300 rounded-s-lg hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white" %>
        </li>
        <% else %>
        <li>
            <span class="flex items-center justify-center h-8 px-3 leading-tight text-gray-500 bg-white border border-gray-300 cursor-not-allowed ms-0 border-e-0 rounded-s-lg">Previous</span>
        </li>
        <% end %>

        <% @products.total_pages.times do |i| %>
        <li>
            <%= link_to i + 1, url_for(page: i + 1), data:{turbo:false}, class: "flex items-center justify-center px-3 h-8 leading-tight #{i + 1 == @products.current_page ? 'text-blue-600 border bg-blue-50 hover:bg-blue-100 hover:text-blue-700' : 'text-gray-500 bg-white border hover:bg-gray-100 hover:text-gray-700'} dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white" %>
        </li>
        <% end %>

        <% if @products.next_page %>
        <li>
            <%= link_to "Next", url_for(page: @products.next_page), data:{turbo:false}, class: "flex items-center justify-center px-3 h-8 leading-tight text-gray-500 bg-white border border-gray-300 rounded-e-lg hover:bg-gray-100 hover:text-gray-700 dark:bg-gray-800 dark:border-gray-700 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-white" %>
        </li>
        <% else %>
        <li>
            <span class="flex items-center justify-center h-8 px-3 leading-tight text-gray-500 bg-white border border-gray-300 cursor-not-allowed rounded-e-lg">Next</span>
        </li>
        <% end %>
    </ul>
</nav>