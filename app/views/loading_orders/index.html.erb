<%= render "/shared/inventory_nav"%>
<%= render "/shared/beer_movement_nav"%>
<div class="px-4 pt-4 bg-white dark:bg-gray-900">
<div class="grid w-full grid-cols-2 gap-4 mb-3">
  <div class="col-span-1">
    <h1 class="text-gray-800 text-md dark:text-gray-100">Beer inventories</h1>
  </div>
  <div class="col-span-1 text-right">
    
  </div>  
</div>
<div class="mb-3">
    <%= form_tag inventories_path, class:"flex items-start max-w-sm", method: :get, data:{turbo_frame:"search_results", turbo_action:"advance", controller:"search", action:"input->search#submit"} do |form| %>
    <label for="simple-search" class="sr-only">Search</label>
    <div class="relative w-full">
        <div class="absolute inset-y-0 flex items-center pointer-events-none start-0 ps-3">
            <svg class="w-4 h-4 text-gray-500 dark:text-gray-400" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 20 20">
                <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m19 19-4-4m0-7A7 7 0 1 1 1 8a7 7 0 0 1 14 0Z"/>
            </svg>
            <span class="sr-only">Search</span>
        </div>
        <%= text_field_tag "query", nil, class:"bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-blue-500 focus:border-blue-500 block w-full ps-10 p-2.5  dark:bg-gray-700 dark:border-gray-600 dark:placeholder-gray-400 dark:text-white dark:focus:ring-blue-500 dark:focus:border-blue-500", placeholder:"Search order ..." %>  
    </div>
    <%end%>
</div>
<!-- Table -->
<div class="flex flex-col mt-6">
  <div class="overflow-x-auto rounded-lg">
    <div class="inline-block min-w-full align-middle">
      <div class="overflow-hidden shadow sm:rounded-lg">
        <div id="inventories">
        <%= turbo_frame_tag "search_results" do%>
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th scope="col" class="p-4 text-xs font-medium tracking-wider text-left text-gray-500 uppercase dark:text-white">
                  Product Details
                </th>
                
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800">
            <% @loading_orders.each_with_index do |order, index| %>
              <tr class="border-b bg-gray-50 dark:bg-gray-800 dark:border-gray-700">
                <td class="w-1/4 p-4 text-sm font-normal text-gray-900 whitespace-nowrap dark:text-white">
                  <div class="flex flex-col space-y-1">
                    <span class="text-sm font-medium"><%= order.loading_date&.strftime("%d %b, %Y") %> (<%= order.order_number %>)</span>
                    <span class="text-xs">Sales Man #: <span class="font-normal"><%= order.sales_person %></span></span>
                    <span class="text-xs">Driver: <span class="font-normal"><%= order.driver_name %></span></span>
                    <span class="text-xs">Vehicle: <span class="font-normal"><%= order.vehicle_numperplate %></span></span>
                    <span class="text-xs">Store: <span class="font-normal"><%= order.store&.name %></span></span>
                    <div class="flex items-center gap-2 mt-2">  
                      <button type="button" class="flex items-center gap-2 p-1 px-3 text-xs text-blue-800 bg-blue-200 rounded dark:text-blue-200 dark:bg-blue-800" id="order-menu-button" aria-expanded="false" data-dropdown-toggle="action-dropdown-<%=order.id%>" data-dropdown-placement="bottom">
                          <span class="flex-1 text-left ms-3 rtl:text-right whitespace-nowrap">Action</span>
                          <svg class="w-2 h-2" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 10 6">
                              <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="m1 1 4 4 4-4"/>
                          </svg>
                      </button>
                  
                      <!-- Dropdown menu -->
                      <div class="z-50 hidden my-4 text-base list-none bg-white divide-y divide-gray-100 rounded-lg shadow dark:bg-gray-700 dark:divide-gray-600" id="action-dropdown-<%=order.id%>">
                          
                          <ul class="py-2" aria-labelledby="order-menu-button">
                              <li>
                                <%= link_to new_beer_return_path(id: order.id), data:{turbo: false}, class:"block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white" do %>Record Return<%end%>
                              </li>
                              <li>
                                <%= link_to edit_loading_order_path(order), data:{turbo: false}, class:"block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white" do %>Edit<%end%>
                              </li>

                              <li>
                                <button data-modal-target="popup-modal-<%=order.id%>" data-modal-toggle="popup-modal-<%=order.id%>" class="block px-4 py-2 text-sm text-gray-700 hover:bg-gray-100 dark:hover:bg-gray-600 dark:text-gray-200 dark:hover:text-white" type="button">Delete</button>
                              </li>
                              
                            
                          </ul>
                      </div>
                    </div>
                  </div>
                </td>
                <td class="p-4 text-sm font-normal text-gray-900 whitespace-normal dark:text-white">
                  <table class="min-w-full border border-collapse border-gray-300 dark:border-gray-700">
                    <thead>
                      <tr class="bg-gray-100 dark:bg-gray-800">
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">Product</th>
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">Qty Loaded</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% order.loading_order_items.each_with_index do |item, index| %>
                        <tr>
                          <td class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700"><%= item.nile_product.name %></td>
                          <td class="px-2 py-1 text-xs font-normal text-right border border-gray-300 dark:border-gray-700"><%= number_with_delimiter(item.quantity_loaded) %></td>
                        </tr>
                      <% end %>
                    </tbody>
                  </table>
                </td>
                
              </tr>
              <%= render "confirm_delete_modal", item: order%>
            <%end%>
            </tbody>
          </table>
          <%= render "pagination" %>
        <%end%>
        </div>
      </div>
    </div>
  </div>
</div>
