<div id="<%= dom_id expense %>">
  <p>
    <strong>Expense type:</strong>
    <%= expense.expense_type_id %>
  </p>

  <p>
    <strong>Expense category:</strong>
    <%= expense.expense_category_id %>
  </p>

  <p>
    <strong>User:</strong>
    <%= expense.user_id %>
  </p>

  <p>
    <strong>Territory:</strong>
    <%= expense.territory_id %>
