<%= render "shared/order_nav"%>
<div class="px-4 pt-4 bg-white dark:bg-gray-900">
<div class="grid w-full grid-cols-2 gap-4 mb-3">
  <div class="col-span-1">
    <h1 class="text-gray-800 text-md dark:text-gray-100">Beer inventories</h1>
  </div>
  <div class="col-span-1 text-right">
    <%= link_to "Export Excel",
    export_inventories_path(
      query: params[:query],
      start_date: params[:start_date],
      end_date: params[:end_date]
    ),
    class: "px-4 py-2 text-sm text-white bg-green-600 rounded-lg hover:bg-green-700",
    data: { turbo: false } %>
  </div>  
</div>
<!-- Filters -->
  <div class="flex w-full mb-3">

    <%= form_tag inventories_path,
      class:"flex items-end gap-2 flex-wrap",
      method: :get,
      data:{
        turbo_frame:"search_results",
        turbo_action:"advance",
        controller:"search",
        action:"input->search#submit"
      } do %>

      <!-- Search -->
      <div class="relative">
        <%= label_tag :query, "Search", class:"block mb-1 text-xs" %>

        <%= text_field_tag "query",
          params[:query],
          class:"bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg block w-full p-2.5",
          placeholder:"Search product ..." %>
      </div>

      <!-- Start Date -->
      <div>
        <%= label_tag :start_date, "From", class:"block mb-1 text-xs" %>

        <%= date_field_tag :start_date,
          params[:start_date],
          class:"bg-gray-50 border border-gray-300 text-sm rounded-lg p-2.5" %>
      </div>

      <!-- End Date -->
      <div>
        <%= label_tag :end_date, "To", class:"block mb-1 text-xs" %>

        <%= date_field_tag :end_date,
          params[:end_date],
          class:"bg-gray-50 border border-gray-300 text-sm rounded-lg p-2.5" %>
      </div>

    <% end %>


</div>
<!-- Table -->
<div class="flex flex-col mt-6">
  <div class="overflow-x-auto rounded-lg">
    <div class="inline-block min-w-full align-middle">
      <div class="overflow-hidden shadow sm:rounded-lg">
        <div id="inventories">
        <%= turbo_frame_tag "search_results" do%>
          <table class="min-w-full divide-y divide-gray-200 dark:divide-gray-600">
            <thead class="bg-gray-50 dark:bg-gray-700">
              <tr>
                <th scope="col" class="p-4 text-xs font-medium tracking-wider text-left text-gray-500 uppercase dark:text-white">
                  Order Details
                </th>
                <th scope="col" class="p-4 text-xs font-medium tracking-wider text-left text-gray-500 uppercase dark:text-white">
                  Product Details
                </th>
                
              </tr>
            </thead>
            <tbody class="bg-white dark:bg-gray-800">
            <% @inventories.each_with_index do |inventory, index| %>
              <tr class="border-b bg-gray-50 dark:bg-gray-800 dark:border-gray-700">
                <td class="p-4 text-sm font-normal text-gray-900 whitespace-nowrap dark:text-white">
                  <div class="flex flex-col space-y-1">
                    <span class="text-sm font-medium"><%= inventory.delivery_time&.strftime("%d %b, %Y") %> (<%= inventory.beer_dispatch.order.order_number %>)</span>
                    <span class="text-xs">Truck No: <span class="font-normal"><%= inventory.beer_dispatch.truck_numberplate %> <%if inventory.beer_dispatch.driver_name? %>(<%= inventory.beer_dispatch.driver_name %>)<% end %></span></span>
                    <span class="text-xs">Warehouse: <span class="font-normal"><%= inventory.warehouse&.name %></span></span>
                    
                  </div>
                </td>
                <td class="p-4 text-sm font-normal text-gray-900 whitespace-normal dark:text-white">
                  <table class="min-w-full border border-collapse border-gray-300 dark:border-gray-700">
                    <thead>
                      <tr class="bg-gray-100 dark:bg-gray-800">
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">Product</th>
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">FDN</th>
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">Qty Received</th>
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">Shortages</th>
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">Complaints</th>
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">Total Qty</th>
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">Rate</th>
                        <th class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700">Purchase Value</th>
                      </tr>
                    </thead>
                    <tbody>
                      <% inventory.inventory_items.each_with_index do |item, index| %>
                        <tr>
                          <td class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700"><%= item.nile_product.name %></td>
                          <td class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700"><%= item.dispatch_item.fdn %></td>
                          <td class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700"><%= number_with_delimiter(item.quantity_received) %></td>
                          <td class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700"><%= number_with_delimiter(item.breakages) %></td>
                          <td class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700"><%= number_with_delimiter(item.complaints) %></td>
                          <td class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700"><%= number_with_delimiter(item.total_quantity) %></td>
                          <td class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700"><%= number_with_delimiter(item.purchase_price, precision: 2) %></td>
                          <td class="px-2 py-1 text-xs font-normal border border-gray-300 dark:border-gray-700"><%= number_with_delimiter(item.total_Purchase, precision: 2) %></td>
                        </tr>
                      <% end %>
                      <tr><td></td><td></td><td></td><td></td><td></td><td></td><td><span class="text-xs font-bold"><%= number_with_delimiter(inventory.total_Purchase, precision: 2) %></span></td></tr>
                    </tbody>
                  </table>
                </td>
                
              </tr>
              <%= render "confirm_delete_modal", inventory: inventory%>
            <%end%>
            </tbody>
          </table>
          <%= render "pagination" %>
        <%end%>
        </div>
      </div>
    </div>
  </div>
</div>
