<%= form_with(model: inventory_transaction) do |form| %>
  <% if inventory_transaction.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(inventory_transaction.errors.count, "error") %> prohibited this inventory_transaction from being saved:</h2>

      <ul>
        <% inventory_transaction.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :inventory_item_id, style: "display: block" %>
    <%= form.text_field :inventory_item_id %>
