<%= render "/shared/inventory_nav"%>
<%= render "/shared/beer_movement_nav"%>
<h2 class="mb-4 text-lg font-bold">
  Reject Transfer
</h2>

<%= form_with model: @stock_transfer,
    url: submit_reject_stock_transfer_path(@stock_transfer),
    method: :patch do |f| %>

  <div class="mt-4">
    <%= f.label :rejection_reason %>
    <%= f.text_area :rejection_reason,
        rows: 5,
        class: "w-full rounded-lg" %>
  </div>

  <div class="mt-4">
    <%= f.submit "Reject Transfer",
        class: "px-4 py-2 text-white bg-red-600 rounded-lg" %>
  </div>

<% end %>