<%= form_with(model: cheque) do |form| %>
  <% if cheque.errors.any? %>
    <div style="color: red">
      <h2><%= pluralize(cheque.errors.count, "error") %> prohibited this cheque from being saved:</h2>

      <ul>
        <% cheque.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :user_id, style: "display: block" %>
    <%= form.text_field :user_id %>
  </div>

  <div>
    <%= form.label :territory_id, style: "display: block" %>
    <%= form.text_field :territory_id %>
  </div>

  <div>
    <%= form.label :bank_transaction_id, style: "display: block" %>
    <%= form.text_field :bank_transaction_id %>
  </div>

  <div>
    <%= form.label :cheque_number, style: "display: block" %>
    <%= form.text_field :cheque_number %>
  </div>

  <div>
    <%= form.label :payee, style: "display: block" %>
    <%= form.text_field :payee %>
  </div>

  <div>
    <%= form.label :status, style: "display: block" %>
    <%= form.text_field :status %>
  </div>

  <div>
    <%= form.label :issue_date, style: "display: block" %>
    <%= form.date_field :issue_date %>
  </div>

  <div>
    <%= form.label :cleared_date, style: "display: block" %>
