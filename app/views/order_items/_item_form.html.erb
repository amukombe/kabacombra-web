<div class="flex items-center justify-between gap-1 px-5 order-item-row nested-form-wrapper" data-new-record="<%= f.object.new_record? %>">
    <div>
        <%= f.label :nile_product_id, 'Product', class:"text-xs text-gray-600 dark:text-gray-400" %> <i class="text-sm text-red-600 dark:text-red-400">*</i>
        <%= f.collection_select :nile_product_id, @products, :id, :name, {prompt: "Choose a product"}, {class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500", data:{controller:"order", action: "change->order#fetchProductDetails"}} %>
    </div>
    <div>
        <%= f.label :quantity , class:"text-xs text-gray-600 dark:text-gray-400"%> <i class="text-sm text-red-600 dark:text-red-400">*</i>
        <%= f.text_field :quantity, step: 1, min: 1 , class:"quantity-field bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500"%>
    </div>
    <div>
        <%= f.label :unit_of_measurement_id, 'Units', class:"text-xs text-gray-600 dark:text-gray-400" %> <i class="text-sm text-red-600 dark:text-red-400">*</i>
        <%= f.collection_select :unit_of_measurement_id, @units, :id, :name, {prompt: "---select---"}, {class: "bg-gray-50 border border-gray-300 text-gray-900 text-sm rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500"} %>
    </div>
    <div data-controller="order">
      <%= f.label :unit_price, class: "text-xs text-gray-600 dark:text-gray-400" %>
      <i class="text-sm text-red-600 dark:text-red-400">*</i>
      <%= f.text_field :unit_price, step: 0.01, class: "unit-price-field bg-gray-50 border border-gray-300 text-gray-900 text-xs rounded-lg focus:ring-primary-600 focus:border-primary-600 block w-full p-2.5 dark:bg-gray-600 dark:border-gray-500 dark:placeholder-gray-400 dark:text-white dark:focus:ring-primary-500 dark:focus:border-primary-500", 
            data: { order_target: "unitPrice" } %>
    </div>

    <div>
        <span class="px-2 py-1 text-xs text-red-200 bg-red-700 rounded dark:text-red-700 dark:bg-red-200">
        <button type="button" data-action="nested-form#remove">Remove <i class="fas fa-trash"></i></button>
        </span>
    </div>
    <%= f.hidden_field :_destroy %>
</div>

