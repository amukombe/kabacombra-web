<div id="<%= dom_id order_item %>">
  <p>
    <strong>Order:</strong>
    <%= order_item.order_id %>
  </p>

  <p>
    <strong>Product:</strong>
    <%= order_item.nile_product_id %>
  </p>

  <p>
    <strong>Quantity:</strong>
    <%= order_item.quantity %>
  </p>

  <p>
    <strong>Unit price:</strong>
    <%= order_item.unit_price %>
  </p>

  <p>
    <strong>Total:</strong>
    <%= order_item.total %>
  </p>

</div>
