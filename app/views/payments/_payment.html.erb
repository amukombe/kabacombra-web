<div id="<%= dom_id payment %>">
  <p>
    <strong>User:</strong>
    <%= payment.user_id %>
  </p>

  <p>
    <strong>Territory:</strong>
    <%= payment.territory_id %>
  </p>

  <p>
    <strong>Financial transaction:</strong>
    <%= payment.financial_transaction_id %>
  </p>

  <p>
    <strong>Payment type:</strong>
    <%= payment.payment_type_id %>
  </p>

  <p>
    <strong>Recipient type:</strong>
    <%= payment.recipient_type %>
  </p>

  <p>
    <strong>Recepient:</strong>
    <%= payment.recepient_id %>
  </p>

  <p>
    <strong>Amount:</strong>
    <%= payment.amount %>
  </p>

  <p>
    <strong>Payment date:</strong>
    <%= payment.payment_date %>
  </p>

</div>
